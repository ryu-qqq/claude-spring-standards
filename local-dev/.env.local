# ===============================================
# 로컬 개발 환경 변수
# ===============================================
# 사용법:
#   docker-compose --env-file .env.local -f docker-compose.local.yml up -d
# ===============================================

# Logging
LOG_LEVEL=DEBUG

# MySQL (로컬 Docker 컨테이너)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=template
MYSQL_USER=template
MYSQL_PASSWORD=template

# Redis (로컬 Docker 컨테이너)
# 비밀번호 없음
