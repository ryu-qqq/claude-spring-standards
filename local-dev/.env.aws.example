# ===============================================
# AWS 연결 환경 변수 예시
# ===============================================
# 사용법:
#   1. 이 파일을 .env.aws로 복사: cp .env.aws.example .env.aws
#   2. 실제 값으로 수정
#   3. 절대 Git에 커밋하지 말 것!
# ===============================================

# -----------------------------------------------
# Spring Profile
# -----------------------------------------------
SPRING_PROFILES_ACTIVE=prod
LOG_LEVEL=INFO

# -----------------------------------------------
# AWS Credentials
# -----------------------------------------------
# IAM User 또는 AWS SSO 자격 증명 사용
# 최소 권한 원칙 적용 권장

AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# (선택) AWS SSO 사용 시 - Session Token
# AWS_SESSION_TOKEN=...

# -----------------------------------------------
# AWS RDS (MySQL)
# -----------------------------------------------
# SSM 포트 포워딩으로 로컬 포트에 매핑됨
# 실제 RDS 엔드포인트: your-rds.xxxx.ap-northeast-2.rds.amazonaws.com

AWS_RDS_LOCAL_PORT=13307
AWS_RDS_DATABASE=template
AWS_RDS_USERNAME=admin
AWS_RDS_PASSWORD=your-rds-password

# -----------------------------------------------
# AWS ElastiCache (Redis)
# -----------------------------------------------
# SSM 포트 포워딩으로 로컬 포트에 매핑됨
# 실제 ElastiCache 엔드포인트: your-redis.xxxx.cache.amazonaws.com

AWS_REDIS_LOCAL_PORT=16380
AWS_REDIS_PASSWORD=

# -----------------------------------------------
# AWS SQS (선택)
# -----------------------------------------------
# AWS_SQS_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/your-queue

# -----------------------------------------------
# AWS S3 (선택)
# -----------------------------------------------
# AWS_S3_BUCKET_NAME=your-bucket-name

# -----------------------------------------------
# SSM Port Forwarding 설정
# -----------------------------------------------
# Bastion Host EC2 Instance ID (SSM Session Manager용)
AWS_BASTION_INSTANCE_ID=i-0123456789abcdef0

# 실제 AWS 리소스 엔드포인트 (포트 포워딩 대상)
AWS_RDS_ENDPOINT=your-rds.cluster-xxxx.ap-northeast-2.rds.amazonaws.com
AWS_RDS_PORT=3306

AWS_REDIS_ENDPOINT=your-redis.xxxx.cache.amazonaws.com
AWS_REDIS_PORT=6379
